rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Standalone Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // STANDALONE SECURITY PRIMITIVES
    function isSignedIn() {
      return request.auth != null;
    }

    function isSaasAdmin() {
      return isSignedIn() && (
        (request.auth.uid == 'system-admin-server') ||
        (request.auth.token.get('email', '').lower() == 'financeirorenanuk@gmail.com') ||
        (request.auth.token.get('email', '').lower() == 'system-admin@kitchenflow.ai') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == "SAAS_ADMIN") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('email', '').lower() == 'financeirorenanuk@gmail.com')
      );
    }

    function userTenantId() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('tenantId', '')
        : '';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Collection Rules
    
    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || 
        isSaasAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource != null && resource.data.get('tenantId', '') == userTenantId())
      );
      allow create, update: if (userId == 'system-admin-server' || request.resource.data.get('email', '') == 'system-admin@kitchenflow.ai') || (isSignedIn() && (
        request.auth.uid == userId || 
        isSaasAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'OWNER' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'ADMIN' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'MANAGER') && request.resource.data.get('tenantId', '') == userTenantId())
      ));
      allow delete: if isSignedIn() && (
        isSaasAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'OWNER' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'ADMIN' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'MANAGER') && resource.data.get('tenantId', '') == userTenantId())
      );
    }

    // Tenants Collection
    match /tenants/{tenantId} {
      allow read: if true; // Publicly readable for digital menu/marketplace/public visitors
      allow create, update: if isSignedIn() && (isSaasAdmin() || request.resource.data.ownerId == request.auth.uid);
      allow delete: if isSaasAdmin();
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true; // Publicly readable for digital menu/marketplace/public visitors
      allow write: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Dining Tables Collection
    match /diningTables/{tableId} {
      allow read: if true; // Publicly readable for digital menu/marketplace/public visitors
      allow write: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Orders Collection
    match /orders/{orderId} {
      allow create: if request.resource.data.tenantId is string
                    && request.resource.data.tenantId.size() > 0
                    && request.resource.data.keys().hasAll(['tenantId', 'items', 'total', 'type', 'status'])
                    && request.resource.data.total is number
                    && request.resource.data.total >= 0
                    && request.resource.data.status in ['pending', 'preparing'];

      allow get: if true;
      allow list: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.tenantId == userTenantId());

      allow update: if isSaasAdmin() || (isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.tenantId is string && resource.data.tenantId == userTenantId()) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.customerPhone == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('phone', '')) ||
        (request.auth.token.get('email', '') != '' && request.auth.token.get('email', '').lower() == resource.data.customerEmail.lower())
      ));
      allow delete: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.tenantId == userTenantId());
    }

    // Customers Collection
    match /customers/{customerId} {
      allow read: if isSaasAdmin() || (isSignedIn() && (
        resource == null || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.tenantId is string && resource.data.tenantId == userTenantId()) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.phone == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('phone', '')) ||
        (request.auth.token.get('email', '') != '' && request.auth.token.get('email', '').lower() == resource.data.email.lower())
      ));
      allow create, update: if isSaasAdmin() || 
                           (request.resource.data.tenantId is string && request.resource.data.tenantId.size() > 0) ||
                           (isSignedIn() && (
                             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && request.resource.data.tenantId is string && request.resource.data.tenantId == userTenantId()) ||
                             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && request.resource.data.phone == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('phone', '')) ||
                             (request.auth.token.get('email', '') != '' && request.auth.token.get('email', '').lower() == request.resource.data.email.lower())
                           ));
      allow delete: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.tenantId == userTenantId());
    }

    // Financial Records Collection
    match /financialRecords/{recordId} {
      allow read: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Bank Accounts Collection
    match /bankAccounts/{accountId} {
      allow read: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Couriers Collection
    match /couriers/{courierId} {
      allow read: if isSaasAdmin() || (isSignedIn() && (
        resource == null || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.tenantId == userTenantId()) ||
        (request.auth.token.get('email', '') != '' && request.auth.token.get('email', '').lower() == resource.data.email.lower())
      ));
      allow write: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Audit Logs Collection
    match /auditLogs/{logId} {
      allow read: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Raw Materials Collection
    match /rawMaterials/{materialId} {
      allow read: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Cash Closings Collection
    match /cashClosings/{closingId} {
      allow read: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Fiscal Notes Collection
    match /fiscalNotes/{noteId} {
      allow read: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Certificates Collection
    match /certificates/{certId} {
      allow read: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Settings Collection
    match /settings/{settingsId} {
      allow read: if true; // Publicly readable for digital menu/marketplace/public visitors
      allow write: if isSaasAdmin() || (isSignedIn() && (request.resource == null || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && request.resource.data.tenantId == userTenantId()) || settingsId == userTenantId()));
    }

    // Plans Collection
    match /plans/{planId} {
      allow read: if true; // Publicly readable so prospective clients can view available plans
      allow write: if isSaasAdmin();
    }

    // Marketplace Invoices Collection
    match /marketplaceInvoices/{invoiceId} {
      allow read: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || isSignedIn();
    }

    // Leads Collection
    match /leads/{leadId} {
      allow read, write: if isSaasAdmin() || isSignedIn();
    }

    // Tickets Collection
    match /tickets/{ticketId} {
      allow read: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || isSignedIn();
    }

    // Commerce Categories Collection
    match /commerceCategories/{categoryId} {
      allow read: if true; // Publicly readable for marketplace categories filtering
      allow write: if isSaasAdmin();
    }

    // Sessions Collection (used by the login refresh-token flow)
    match /sessions/{sessionId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

    // SaaS Ledger Collection (platform's own accounts payable/receivable)
    match /saasLedger/{entryId} {
      allow read, write: if isSaasAdmin();
    }

    // SaaS Payments Collection (tenant billing payments)
    match /saasPayments/{paymentId} {
      allow read: if isSaasAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin();
    }
  }
}
