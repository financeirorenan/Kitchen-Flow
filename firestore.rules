rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // -----------------------------------------------------------------
    // 1. Global Helpers
    // -----------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '').lower() == "financeirorenanuk@gmail.com" ||
        request.auth.token.get('email_verified', false) == true && request.auth.token.get('email', '').lower() == "financeirorenanuk@gmail.com"
      );
    }

    function isSaaSAdmin() {
      // Check if user has SAAS_ADMIN role in their own user document
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'USER') == 'SAAS_ADMIN';
    }

    function canManageSaaS() {
      return isSuperAdmin() || isSaaSAdmin();
    }

    function getTenantId() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
             ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId 
             : "NO_TENANT";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -----------------------------------------------------------------
    // 2. Collection Rules
    // -----------------------------------------------------------------

    // Users
    match /users/{userId} {
      allow read: if true;
      allow create: if true;
      allow update: if canManageSaaS() || isOwner(userId) || true;
    }

    // Couriers
    match /couriers/{courierId} {
      allow read: if true;
      allow write: if canManageSaaS() || isOwner(courierId) || true;
    }

    // Tenants
    match /tenants/{tenantId} {
      allow read: if true; 
      allow write: if canManageSaaS();
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if canManageSaaS() || (isSignedIn() && incoming().tenantId == getTenantId());
    }

    // Categories
    match /categories/{catId} {
      allow read: if true;
      allow write: if canManageSaaS() || (isSignedIn() && incoming().tenantId == getTenantId());
    }

    // Dining Tables
    match /diningTables/{tableId} {
      allow read: if true;
      allow write: if canManageSaaS() || (isSignedIn() && (incoming().tenantId == getTenantId() || existing().tenantId == getTenantId()));
    }

    // Settings
    match /settings/{tenantId} {
      allow read: if true;
      allow write: if canManageSaaS() || (isSignedIn() && tenantId == getTenantId());
    }

    // Orders
    match /orders/{orderId} {
      allow read: if true; 
      allow create: if true;
      allow update, delete: if canManageSaaS() || (isSignedIn() && (resource.data.tenantId == getTenantId() || resource.data.customerId == request.auth.uid));
    }

    // Marketplace Invoices
    match /marketplaceInvoices/{invoiceId} {
      allow read: if canManageSaaS() || (isSignedIn() && resource.data.tenantId == getTenantId());
      allow create: if true;
      allow update, delete: if canManageSaaS();
    }

    // Tenant-isolated collections (customers, etc.)
    match /{collection}/{docId} {
      allow read: if canManageSaaS() || (isSignedIn() && (
        collection in ['plans', 'leads', 'tickets', 'marketplaceInvoices'] || 
        (resource != null && resource.data.tenantId == getTenantId())
      ));
      allow write: if canManageSaaS() || (isSignedIn() && (
        collection in ['marketplaceInvoices', 'leads', 'orders', 'tickets'] ||
        (request.resource != null && (collection == 'leads' || incoming().tenantId == getTenantId()))
      ));
    }

    // Plans
    match /plans/{planId} {
      allow read: if true;
      allow write: if canManageSaaS();
    }

    // Commerce Categories
    match /commerceCategories/{catId} {
      allow read: if true;
      allow write: if canManageSaaS();
    }

    // Default deny as catch-all
    match /{document=**} {
      allow read, write: if isSignedIn() && (
        isSuperAdmin() || 
        canManageSaaS()
      );
    }
  }
}

