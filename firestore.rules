rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Standalone Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // STANDALONE SECURITY PRIMITIVES (Phase 3)
    function isSignedIn() {
      return request.auth != null;
    }

    function hasUserData() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSaasAdmin() {
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email.lower() == 'financeirorenanuk@gmail.com') ||
        (hasUserData() && (
          getUserData().role == "SAAS_ADMIN" || 
          getUserData().email.lower() == "financeirorenanuk@gmail.com"
        ))
      );
    }

    function userTenantId() {
      return hasUserData() ? getUserData().tenantId : "";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Collection Rules
    
    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || 
        isSaasAdmin() || 
        (hasUserData() && resource.data.tenantId == getUserData().tenantId)
      );
      allow create, update: if isSignedIn() && (
        request.auth.uid == userId || 
        isSaasAdmin() || 
        (hasUserData() && (getUserData().role == 'OWNER' || getUserData().role == 'ADMIN' || getUserData().role == 'MANAGER') && request.resource.data.tenantId == getUserData().tenantId)
      );
      allow delete: if isSignedIn() && (
        isSaasAdmin() || 
        (hasUserData() && (getUserData().role == 'OWNER' || getUserData().role == 'ADMIN' || getUserData().role == 'MANAGER') && resource.data.tenantId == getUserData().tenantId)
      );
    }

    // Tenants Collection
    match /tenants/{tenantId} {
      allow read: if true; // Publicly readable for digital menu/marketplace/public visitors
      allow create, update: if isSignedIn() && (isSaasAdmin() || request.resource.data.ownerId == request.auth.uid);
      allow delete: if isSaasAdmin();
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true; // Publicly readable for digital menu/marketplace/public visitors
      allow write: if isSaasAdmin() || (isSignedIn() && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Dining Tables Collection
    match /diningTables/{tableId} {
      allow read: if true; // Publicly readable for digital menu/marketplace/public visitors
      allow write: if isSaasAdmin() || (isSignedIn() && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Orders Collection
    match /orders/{orderId} {
      // Guest checkout (cardápio digital/marketplace): permite CRIAR um pedido
      // novo sem login, mas valida a forma do documento para impedir que um
      // estranho injete campos arbitrários ou sobrescreva um pedido existente.
      allow create: if request.resource.data.tenantId is string
                    && request.resource.data.tenantId.size() > 0
                    && request.resource.data.keys().hasAll(['tenantId', 'items', 'total', 'type', 'status'])
                    && request.resource.data.total is number
                    && request.resource.data.total >= 0
                    && request.resource.data.status in ['pending', 'preparing'];

      // Ler ou alterar um pedido já existente exige ser da equipe do próprio
      // tenant (ou SAAS_ADMIN), ou ser o cliente proprietário do pedido.
      allow read: if isSaasAdmin() || (isSignedIn() && (
        resource.data.tenantId == userTenantId() ||
        ('phone' in getUserData() && resource.data.customerPhone == getUserData().phone) ||
        ('email' in request.auth.token && resource.data.customerEmail == request.auth.token.email)
      ));
      allow update: if isSaasAdmin() || (isSignedIn() && (
        resource.data.tenantId == userTenantId() ||
        ('phone' in getUserData() && resource.data.customerPhone == getUserData().phone) ||
        ('email' in request.auth.token && resource.data.customerEmail == request.auth.token.email)
      ));
      allow delete: if isSaasAdmin() || (isSignedIn() && resource.data.tenantId == userTenantId());
    }

    // Customers Collection
    match /customers/{customerId} {
      allow read: if isSaasAdmin() || (isSignedIn() && (
        resource == null || 
        resource.data.tenantId == userTenantId() ||
        ('phone' in getUserData() && resource.data.phone == getUserData().phone) ||
        ('email' in request.auth.token && resource.data.email == request.auth.token.email)
      ));
      allow write: if isSaasAdmin() || (isSignedIn() && (
        request.resource == null || 
        request.resource.data.tenantId == userTenantId() ||
        ('phone' in getUserData() && request.resource.data.phone == getUserData().phone) ||
        ('email' in request.auth.token && request.resource.data.email == request.auth.token.email)
      ));
    }

    // Financial Records Collection
    match /financialRecords/{recordId} {
      allow read: if isSaasAdmin() || (isSignedIn() && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || (isSignedIn() && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Bank Accounts Collection
    match /bankAccounts/{accountId} {
      allow read: if isSaasAdmin() || (isSignedIn() && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || (isSignedIn() && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Couriers Collection
    match /couriers/{courierId} {
      allow read: if isSaasAdmin() || (isSignedIn() && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || (isSignedIn() && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Audit Logs Collection
    match /auditLogs/{logId} {
      allow read: if isSaasAdmin() || (isSignedIn() && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || (isSignedIn() && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Raw Materials Collection
    match /rawMaterials/{materialId} {
      allow read: if isSaasAdmin() || (isSignedIn() && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || (isSignedIn() && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Cash Closings Collection
    match /cashClosings/{closingId} {
      allow read: if isSaasAdmin() || (isSignedIn() && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || (isSignedIn() && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Fiscal Notes Collection
    match /fiscalNotes/{noteId} {
      allow read: if isSaasAdmin() || (isSignedIn() && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || (isSignedIn() && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Certificates Collection
    match /certificates/{certId} {
      allow read: if isSaasAdmin() || (isSignedIn() && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || (isSignedIn() && (request.resource == null || request.resource.data.tenantId == userTenantId()));
    }

    // Settings Collection
    match /settings/{settingsId} {
      allow read: if true; // Publicly readable for digital menu/marketplace/public visitors
      allow write: if isSaasAdmin() || (isSignedIn() && (request.resource == null || request.resource.data.tenantId == userTenantId() || settingsId == userTenantId()));
    }

    // Plans Collection
    match /plans/{planId} {
      allow read: if true; // Publicly readable so prospective clients can view available plans
      allow write: if isSaasAdmin();
    }

    // Marketplace Invoices Collection
    match /marketplaceInvoices/{invoiceId} {
      allow read: if isSaasAdmin() || (isSignedIn() && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || isSignedIn();
    }

    // Leads Collection
    match /leads/{leadId} {
      allow read, write: if isSaasAdmin() || isSignedIn();
    }

    // Tickets Collection
    match /tickets/{ticketId} {
      allow read: if isSaasAdmin() || (isSignedIn() && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin() || isSignedIn();
    }

    // Commerce Categories Collection
    match /commerceCategories/{categoryId} {
      allow read: if true; // Publicly readable for marketplace categories filtering
      allow write: if isSaasAdmin();
    }

    // Sessions Collection (used by the login refresh-token flow)
    match /sessions/{sessionId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

    // SaaS Ledger Collection (platform's own accounts payable/receivable)
    match /saasLedger/{entryId} {
      allow read, write: if isSaasAdmin();
    }

    // SaaS Payments Collection (tenant billing payments)
    match /saasPayments/{paymentId} {
      allow read: if isSaasAdmin() || (isSignedIn() && (resource == null || resource.data.tenantId == userTenantId()));
      allow write: if isSaasAdmin();
    }
  }
}
